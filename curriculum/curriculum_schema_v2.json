{
  "schema_version": "2.0",

  "structure": ["grade", "skills", "templates"],

  "global_rules": {
    "enforce_skill_boundaries": true,
    "reject_cross_grade_operations": true,
    "no_default_arithmetic_in_higher_grades": true,

      "grade_purity_rules": {
      "5th": ["whole_numbers_only", "basic_fractions_conceptual"],
      "mid-5th": ["whole_numbers", "intro_fractions", "no_negatives"],
      "6th": ["integers", "fraction_operations", "decimals", "ratios_intro"],
      "mid-6th": ["ratios", "fraction_operations_limited_scope", "decimals", "geometry_basics"],
      "7th": ["proportions", "percent_equations", "linear_equations", "coordinate_reasoning"],
      "mid-7th": ["multi_step_equations", "advanced_ratios", "percent_applications"],
      "8th": ["systems", "linear_functions", "rational_expressions_intro"]
    },

    "hard_rejection_rules": [
      "no_grade_may_contain_unapproved_operations",
      "no_grade_may_use_skills_outside_grade_band",
      "no_template_may_introduce_lower_or_higher_grade_concepts",
      "no_pure_arithmetic_generation_outside_grade_intent",
      "no_skill_can_override_grade_constraints"
    ],

    "universal_constraints": {
      "5th": {
        "allowed": ["whole_numbers", "basic_fractions_conceptual"],
        "forbidden": ["negatives", "decimals", "fraction_operations", "algebra", "variables"]
      },
      "mid-5th": {
        "allowed": ["whole_numbers", "intro_fractions", "basic_word_problems"],
        "forbidden": ["negatives", "multi_step_algebra", "equations"]
      },
      "6th": {
        "allowed": ["integers", "fraction_operations", "decimals", "ratios_intro", "basic_geometry"],
        "forbidden": ["advanced_algebra", "systems_of_equations", "multi-step proportion_algebra"]
      },
      "mid-6th": {
        "allowed": ["ratios", "fraction_operations_limited", "decimals", "geometry_basics"],
        "forbidden": ["algebraic_equations", "fraction_division_as_primary_task", "systems_of_equations"]
      },
      "7th": {
        "allowed": ["proportions", "percent_equations", "linear_equations", "coordinate_reasoning"],
        "forbidden": ["integer_only_arithmetic", "pure_fraction_arithmetic", "basic_6th_grade_skill_as_primary_task"]
      },
      "mid-7th": {
        "allowed": ["multi_step_equations", "advanced_ratios", "percent_applications"],
        "forbidden": ["6th_grade_core_arithmetic_as_primary", "simple_integer_only_problems"]
      },
      "8th": {
        "allowed": ["systems_of_equations", "linear_functions", "rational_expressions_intro"],
        "forbidden": ["basic_arithmetic_only_tasks", "6th_grade_skill_repetition"]
      }
    }
  },

  "validation_contract": {
    "step_1": "match_grade_to_universal_constraints",
    "step_2": "validate_skill_belongs_to_grade_band",
    "step_3": "reject_if_any_forbidden_operation_detected",
    "step_4": "reject_if_problem_is_lower_grade_skill_without_transformation",
    "step_5": "regenerate_from_valid_template_only"
  },

  "generation_contract": {
    "only_generate_from_templates": true,
    "never_infer_math_outside_grade_band": true,
    "no_freeform_arithmetic_generation": true,
    "strict_grade_isolation": true
  }
}
