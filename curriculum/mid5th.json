            "c": [
              4,
              8
            ],
            "d": [
              2,
              4
            ]
          },
          "answer_type": "mixed_number",
          "answer_formula": "((a * c + b) * d) / c"
        },
        {
          "id": "fm_005",
          "type": "APPLY",
          "context": "construction",
          "problem": "A board is {a} {b}/{c} feet long. You cut off {d} {e}/{c} feet. How long is the remaining piece?",
          "constraints": {
            "a": [
              4,
              8
            ],
            "b": [
              3,
              7
            ],
            "c": [
              4,
              8
            ],
            "d": [
              1,
              3
            ],
            "e": [
              1,
              5
            ]
          },
          "answer_type": "mixed_number",
          "answer_formula": "(a - c) / b"
        },
        {
          "id": "fm_006",
          "type": "REVERSE",
          "problem": "{a} {b}/{c} + __ = {d} {e}/{c}. Find the missing mixed number.",
          "constraints": {
            "a": [
              1,
              3
            ],
            "b": [
              1,
              4
            ],
            "c": [
              6,
              8
            ],
            "d": [
              4,
              7
            ],
            "e": [
              3,
              7
            ]
          },
          "answer_type": "mixed_number",
          "answer_formula": "(d - a) + (e - b) / c"
        },
        {
          "id": "fm_007",
          "type": "COMPARE",
          "problem": "Which is greater: {a} {b}/{c} or {d} {e}/{c}?",
          "constraints": {
            "a": [
              2,
              5
