    {
      "id": "fraction_operations_advanced",
      "name": "Fraction Operations with Mixed Numbers",
      "ccss": "5.NF.A.1, 5.NF.B.4, 5.NF.B.6",
      "level": "solidify",
      "templates": [
        {
          "id": "fm_001",
          "type": "COMPUTE",
          "problem": "{a} {b}/{c} + {d} {e}/{c}",
          "constraints": {
            "a": [
              1,
              5
            ],
            "b": [
              1,
              5
            ],
            "c": [
              4,
              8
            ],
            "d": [
              1,
              5
            ],
            "e": [
              1,
              5
            ]
          },
          "answer_type": "mixed_number",
          "answer_formula": "(a + d) + (b + e) / c"
        },
        {
          "id": "fm_002",
          "type": "COMPUTE",
          "problem": "{a} {b}/{c} - {d} {e}/{c}",
          "constraints": {
            "a": [
              3,
              8
            ],
            "b": [
              3,
              7
            ],
            "c": [
              4,
              8
            ],
            "d": [
              1,
              4
            ],
            "e": [
              1,
              6
            ]
          },
          "constraints_note": "result positive",
          "answer_type": "mixed_number",
          "answer_formula": "(a - d) + (b - e) / c"
        },
        {
          "id": "fm_003",
          "type": "COMPUTE",
          "problem": "{a} {b}/{c} × {d}",
          "constraints": {
            "a": [
              1,
              4
            ],
            "b": [
              1,
              4
            ],
            "c": [
              3,
              8
            ],
            "d": [
              2,
              5
            ]
          },
          "answer_type": "mixed_number",
          "answer_formula": "(a + b/c) * d"
        },
        {
          "id": "fm_004",
          "type": "APPLY",
          "context": "cooking",
          "problem": "A recipe uses {a} {b}/{c} cups of flour. You want to make {d} batches. How much flour do you need in total?",
          "constraints": {
            "a": [
              1,
              3
